digraph G {
  node [shape=box];
  "$1" [label="Tx $1\n@alice ->\n@bob:0.10\nTx1", style=filled, fillcolor=lightblue];
  "$3" [label="Tx $3\n@bob ->\n@alice:0.05\nTx2", style=filled, fillcolor=lightblue];
  "$0" [label="Summary $0\n", style=filled, fillcolor=lightgreen];
  "$2" [label="Summary $2\n@alice: 0.10\n@bob: 0.10", style=filled, fillcolor=lightgreen];
  "ind_$2_$0" [shape=point];
  "$2" -> "ind_$2_$0" [color=green];
  "ind_$2_$0" -> "$0" [color=green];
  "ind_$2_$0" -> "$1" [color=blue];
  "$4" [label="Summary $4\n@alice: 0.05\n@bob: 0.05", style=filled, fillcolor=lightgreen];
  "ind_$4_$2" [shape=point];
  "$4" -> "ind_$4_$2" [color=green];
  "ind_$4_$2" -> "$2" [color=green];
  "ind_$4_$2" -> "$3" [color=blue];
}
