digraph G {
  node [shape=box];
  "$0" [label="Tx $0\n@testuser ->\n@bob:1.00\nDinner", style=filled, fillcolor=lightblue];
  "$1" [label="Summary $1\n", style=filled, fillcolor=lightgreen];
  "$2" [label="Summary $2\n@alice: -1.00\n@bob: 1.00", style=filled, fillcolor=lightgreen];
  "ind_$2_$1" [shape=point];
  "$2" -> "ind_$2_$1" [color=green];
  "ind_$2_$1" -> "$1" [color=green];
  "ind_$2_$1" -> "$0" [color=blue];
}
